---
import ClustersManager from "@/components/admin/clusters-manager.svelte"
import ClusterForm from "@/components/admin/cluster-form.svelte"
import AdminLayout from "@/layouts/admin-layout.astro"
import { db } from "@/lib/db/client"
import { clustersTable } from "@/lib/db/schemas"
import { asc } from "drizzle-orm"

const clusters = await db.query.clustersTable.findMany({
  orderBy: [asc(clustersTable.topic)],
})
---

<AdminLayout title="Clusters — Admin">
  <div class="space-y-8">
    <div>
      <h2 class="text-2xl font-bold tracking-tight">Topic Clusters</h2>
      <p class="text-muted-foreground">
        Define topic clusters and configure AI models for article summarization.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <ClustersManager {clusters} client:load />
      </div>

      <div>
        <div id="cluster-form">
          <ClusterForm
            onSuccess={() => window.location.reload()}
            client:load
          />
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
